    { "mki": 0, "operator": "apex", "quarter": "2025-04-01", "tests": 5, "download_mbps": 40 },
    { "mki": 0, "operator": "zenith", "quarter": "2025-01-01", "tests": 3, "download_mbps": 90 },
    { "mki": 1, "operator": "zenith", "quarter": "2025-01-01", "tests": 8, "download_mbps": 20 },
    { "mki": 1, "operator": "zenith", "quarter": "2025-07-01", "tests": 4, "download_mbps": 60 }
  ],
  "sparse": {
    "offsets": [0, 3, 5],
    "cellIds": [0, 1, 3, 3, 5],
    "planes": {
      "sum__tests": [10, 5, 3, 8, 4],
      "cnt": [1, 1, 1, 1, 1],
